# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# GitHub Personal Access Token — needs 'repo' scope.
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_pat_here
# --- Atlassian ----------------------------------------------------------------
# Your Atlassian account email
ATLASSIAN_EMAIL=you@example.com

# Atlassian site subdomain — the part before .atlassian.net
# e.g. if your Jira is at https://mycompany.atlassian.net, set: mycompany
ATLASSIAN_SITE=mycompany

# Atlassian API token (not your password)
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_API_TOKEN=your_atlassian_api_token_here